# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it's in .gitignore by default.
# After editing, restart the dev server (Ctrl-C, then `npm run dev`).

# ─── Supabase (required) ──────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Gmail bank-alert sync (optional, Phase B) ────────────────────────────
# DEPRECATED — replaced by inbound email forwarding (ForwardAddressCard +
# /api/inbound/email). Kept for migration reference only.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Inbound email forwarding ──────────────────────────────────────────────
# The domain that receives forwarded bank emails
NEXT_PUBLIC_INBOUND_DOMAIN=inbound.aureus.app
# Shared secret for the /api/inbound/email webhook (set this to a random string)
INBOUND_EMAIL_SECRET=your-random-secret-here
# Supabase service role key (for inserting transactions server-side, bypassing RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Sentry (optional) ────────────────────────────────────────────────────
# If set, the /api/log route forwards client errors to your Sentry project.
# DSN format: https://<key>@<host>/<project_id>
# SENTRY_DSN=
