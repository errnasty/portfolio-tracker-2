# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it's in .gitignore by default.
# After editing, restart the dev server (Ctrl-C, then `npm run dev`).

# ─── Supabase (required) ──────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Gmail bank-alert sync (optional, Phase B) ────────────────────────────
# Lets /api/bank/gmail-sync read DBS/POSB transaction-alert emails.
# Setup: Google Cloud project → enable Gmail API → OAuth consent screen →
# create OAuth client (Web). Then in Supabase: Authentication → Providers →
# Google, paste the same client id/secret and add scope
# https://www.googleapis.com/auth/gmail.readonly
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Sentry (optional) ────────────────────────────────────────────────────
# If set, the /api/log route forwards client errors to your Sentry project.
# DSN format: https://<key>@<host>/<project_id>
# SENTRY_DSN=
